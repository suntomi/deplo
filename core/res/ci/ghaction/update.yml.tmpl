# generated by deplo CLI https://github.com/suntomi/deplo don't edit by hand.
name: Deplo Update

on:
  workflow_dispatch:
    inputs:
      version:
        required: false
        description: Target deplo version. If empty, the latest GitHub release is used.
  schedule:
    - cron: {update_check_schedule}

permissions:
  contents: write
  pull-requests: write
  issues: write

env:
{common_envs:>2}
  DEPLO_UPDATE_CURRENT_VERSION: {current_version}
  DEPLO_UPDATE_VERSION_PATTERN: ${{{{ vars.DEPLO_UPDATE_VERSION_PATTERN || '^[0-9]+\.[0-9]+\.[0-9]+$' }}}}
{secrets:>2}

jobs:
  deplo-update:
    runs-on: ubuntu-latest
    steps:
{fetchcli:>6}
{checkout:>6}
      - name: Resolve deplo version
        id: version
        shell: bash
        run: |
          set -euo pipefail
          current="$DEPLO_UPDATE_CURRENT_VERSION"
          requested="${{{{ github.event.inputs.version || '' }}}}"
          latest="$requested"
          if [ -z "$latest" ]; then
            latest=$(curl -fsSL https://api.github.com/repos/suntomi/deplo/releases/latest | jq -r '.tag_name // empty')
          fi
          if [ -z "$latest" ]; then
            echo "failed to resolve latest deplo version" >&2
            exit 1
          fi
          if ! printf '%s' "$latest" | grep -Eq "$DEPLO_UPDATE_VERSION_PATTERN"; then
            echo "deplo version $latest does not match update pattern $DEPLO_UPDATE_VERSION_PATTERN"
            echo "should_update=false" >> "$GITHUB_OUTPUT"
            exit 0
          fi
          if [ "$latest" = "$current" ]; then
            echo "deplo is already up to date: $current"
            echo "should_update=false" >> "$GITHUB_OUTPUT"
            exit 0
          fi
          echo "should_update=true" >> "$GITHUB_OUTPUT"
          echo "latest=$latest" >> "$GITHUB_OUTPUT"
      - name: Download latest deplo
        if: steps.version.outputs.should_update == 'true'
        shell: bash
        run: |
          set -euo pipefail
          latest="${{{{ steps.version.outputs.latest }}}}"
          curl -fL "{release_url_base}/$latest/deplo-Linux-$(uname -m)" -o /tmp/deplo-latest
          chmod +x /tmp/deplo-latest
      - name: Check existing update pull request
        id: existing-pr
        if: steps.version.outputs.should_update == 'true'
        shell: bash
        env:
          GH_APP_TOKEN: ${{{{ steps.app-token.outputs.token }}}}
        run: |
          set -euo pipefail
          remote_url="https://x-access-token:$GH_APP_TOKEN@github.com/${{{{ github.repository }}}}.git"
          latest="${{{{ steps.version.outputs.latest }}}}"
          expected_title="Update deplo to $latest"
          open_update_prs=$(/tmp/deplo-latest vcs pr search -f state=open -f labels=deplo-update)
          printf '%s' "$open_update_prs" | jq -c '.[]' | while read -r pr; do
            title=$(printf '%s' "$pr" | jq -r '.title')
            url=$(printf '%s' "$pr" | jq -r '.html_url')
            echo "check with existing open deplo update pull request: $title ($url)"
            if [ -z "$url" ]; then
              echo "skip closing deplo update pull request with empty URL"
              continue
            fi
            if [ "$title" = "$expected_title" ]; then
              echo "skip closing deplo update pull request with same version: $title $expected_title ($url)"
              continue
            fi
            /tmp/deplo-latest vcs pr close "$url" -o message="Closing superseded deplo update pull request (for $latest)."
            if [[ "$title" == "Update deplo to "* ]]; then
              version=$(printf '%s' "$title" | sed 's/^Update deplo to //')
              if [ -z "$version" ] || printf '%s' "$version" | grep -Eq '[^A-Za-z0-9._-]'; then
                echo "skip deleting deplo update branch for unexpected version: $version"
              else
                branch="deplo/update-$version"
                if git ls-remote --exit-code --heads "$remote_url" "$branch" >/dev/null 2>&1; then
                  echo "deleting deplo update branch: $branch"
                  git push "$remote_url" --delete "$branch"
                else
                  echo "deplo update branch already absent: $branch"
                fi
              fi
            else
              echo "skip deleting deplo update branch for unexpected title: $title vs $expected_title"
            fi
          done
          if printf '%s' "$open_update_prs" | jq -e --arg expected_title "$expected_title" 'any(.[]; .title == $expected_title)' >/dev/null; then
            echo "same version deplo update pull request already exists"
            echo "same_version_found=true" >> "$GITHUB_OUTPUT"
          else
            echo "same_version_found=false" >> "$GITHUB_OUTPUT"
          fi
      - name: Regenerate deplo files
        if: steps.existing-pr.conclusion == 'success' && steps.existing-pr.outputs.same_version_found != 'true'
        shell: bash
        run: |
          set -euo pipefail
          /tmp/deplo-latest init
      - name: Commit update
        if: steps.existing-pr.conclusion == 'success' && steps.existing-pr.outputs.same_version_found != 'true'
        id: commit
        shell: bash
        env:
          GH_APP_TOKEN: ${{{{ steps.app-token.outputs.token }}}}
        run: |
          set -euo pipefail
          latest="${{{{ steps.version.outputs.latest }}}}"
          branch="deplo/update-$latest"
          base="${{{{ github.event.repository.default_branch }}}}"
          git config user.name "deplo[bot]"
          git config user.email "deplo[bot]@users.noreply.github.com"
          git checkout -B "$branch"
          git add deplow .github/workflows
          if git diff --cached --quiet; then
            echo "no generated deplo file changes"
            echo "has_changes=false" >> "$GITHUB_OUTPUT"
            exit 0
          fi
          git commit -m "Update deplo to $latest"
          git push --force-with-lease "https://x-access-token:$GH_APP_TOKEN@github.com/${{{{ github.repository }}}}.git" "$branch"
          echo "has_changes=true" >> "$GITHUB_OUTPUT"
          echo "branch=$branch" >> "$GITHUB_OUTPUT"
          echo "base=$base" >> "$GITHUB_OUTPUT"
      - name: Prepare update pull requests
        id: update-prs
        if: steps.commit.outputs.has_changes == 'true'
        shell: bash
        run: |
          set -euo pipefail
          /tmp/deplo-latest vcs label create deplo-update -c FFFF00 || true
      - name: Create update pull request
        if: steps.commit.outputs.has_changes == 'true'
        shell: bash
        run: |
          set -euo pipefail
          latest="${{{{ steps.version.outputs.latest }}}}"
          branch="${{{{ steps.commit.outputs.branch }}}}"
          base="${{{{ steps.commit.outputs.base }}}}"
          /tmp/deplo-latest vcs pr create \
            -o title="Update deplo to $latest" \
            -o head="$branch" \
            -o base="$base" \
            -o body="Updates generated deplo wrapper and workflow files to $latest." \
            -o labels='["deplo-update"]'
